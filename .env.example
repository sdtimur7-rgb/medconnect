# Database
DB_PASSWORD=your_strong_password_here
DATABASE_URL=postgresql+asyncpg://medconnect:your_strong_password_here@postgres/medconnect

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Telegram Bot (для тестирования - главный токен)
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_TELEGRAM_ID=your_telegram_id

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# SMS Center API (smsc.ru)
SMSC_LOGIN=your_smsc_login
SMSC_PASSWORD=your_smsc_password
SMSC_ENABLED=true

# Chatwoot
CHATWOOT_API_URL=http://chatwoot:3000
CHATWOOT_API_TOKEN=your_chatwoot_api_token
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_SECRET_KEY=generate_random_secret_key_here
CHATWOOT_FRONTEND_URL=http://localhost:3000

# Application
APP_NAME=MedConnect
DEBUG=false
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000

# Monitoring (optional)
SENTRY_DSN=
